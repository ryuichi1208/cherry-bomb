# cherry-bomb SRE AI Agent - Environment Variables

# Required: Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Required: Slack
SLACK_BOT_TOKEN=xoxb-xxxxx
SLACK_SIGNING_SECRET=xxxxx
# Optional: Socket Mode (for local development without public URL)
# SLACK_APP_TOKEN=xapp-xxxxx

# Claude Model
CLAUDE_MODEL=claude-sonnet-4-20250514

# AWS
AWS_REGION=ap-northeast-1
DYNAMODB_TABLE_NAME=cherry-bomb-approvals
# SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/cherry-bomb-approvals

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Datadog Plugin (optional)
# DD_API_KEY=xxxxx
# DD_APP_KEY=xxxxx
# DD_SITE=datadoghq.com
